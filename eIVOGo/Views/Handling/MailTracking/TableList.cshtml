@using System.IO
@using System.Linq.Expressions
@using eIVOGo.Resource.Views.Handling.MailTracking

@using Model.DataEntity
@using Model.Locale
@using Newtonsoft.Json

@{
    List<InvoiceItem> _items;
    List<InvoiceItem> _model;
    _model = (List<InvoiceItem>)this.Model;
    _items = _model;
}

<div class="border_gray" style="overflow-x: auto; max-width: 1024px;">
    <table border="0" cellpadding="0" cellspacing="0" class="left_title">
        <tr>
            <td class="Bargain_btn">
                <button type="button" onclick="uiHandling.processPack();">@TableList.整理郵件號碼</button>
            </td>
        </tr>
    </table>
    <table class="table01 itemList">
        <thead>
            <tr>
                <th style="min-width: 80px;">@TableList.寄送日期</th>
                <th style="min-width: 120px;">GoogleID</th>
                <th style="min-width: 120px;">@TableList.發票號碼</th>
                <th style="min-width: 320px;">@TableList.掛號號碼</th>
                <th style="min-width: 120px;">@TableList.收件人</th>
                <th style="min-width: 280px;">@TableList.收件人地址</th>
                <th style="min-width: 60px;">@TableList.備考</th>
                <th>@TableList.作業方式</th>
                <th>@TableList.附件張數</th>
                <th style="min-width: 150px;">&nbsp;</th>
            </tr>
        </thead>
        <tbody>
            @{ Html.RenderPartial("~/Views/Handling/MailTracking/ItemList.cshtml", _model);}

        </tbody>
        <tfoot>
            <tr>
                <td colspan="8" class="Bargain_btn">
                    <button type="button" onclick="uiHandling.inquireTracking();">@TableList.存檔</button>&nbsp;
                    <button type="button" onclick="uiHandling.download();">@TableList.下載</button>
                    <button type="button" onclick="uiHandling.zipAll();">@TableList.列印資料下載_ZIP_</button>
                </td>
            </tr>
        </tfoot>
    </table>
</div>


