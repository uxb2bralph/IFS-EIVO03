@using eIVOGo.Helper
@using Model.Locale
@using eIVOGo.Models.ViewModel
@using Model.Models.ViewModel
@using Model.DataEntity
@using eIVOGo.Controllers
@using res = eIVOGo.Resource.Views.BusinessRelationship.Module.ItemList

@{
    Layout = null;

    IQueryable<BusinessRelationship> _items;
    BusinessRelationshipQueryViewModel _viewModel;

    _viewModel = (BusinessRelationshipQueryViewModel)ViewBag.ViewModel;
    _items = ((IQueryable<BusinessRelationship>)this.Model).Skip(_viewModel.PageIndex.Value * _viewModel.PageSize.Value)
        .Take(_viewModel.PageSize.Value);
}

<table class="table01 businessList">
    <thead>
        <tr>
            <th style="min-width: 200px">@res.集團成員</th>
            <th style="min-width: 200px">@res.相對營業人名稱</th>
            <th style="min-width: 80px">@res.統一編號</th>
            <th style="min-width: 50px">@res.類別</th>
            <th style="min-width: 120px">@res.聯絡人電子郵件</th>
            <th style="min-width: 200px">@res.地址</th>
            <th style="min-width: 120px">@res.電話</th>
            <th style="min-width: 120px">@res.店號</th>
            <th style="min-width: 60px">@res.狀態</th>
            <th style="min-width: 150px">@res.管理</th>
        </tr>
    </thead>
    <tbody>
        @{ int idx = 0; }
        @foreach (var item in _items)
        {
            idx++;
            Html.RenderPartial("~/Views/BusinessRelationship/Module/DataItem.cshtml", item);
        }
        @{Html.RenderPartial("~/Views/BusinessRelationship/Module/AddItem.cshtml"); }
    </tbody>
    <tfoot>
        <tr>
            <td colspan="10">&nbsp;</td>
        </tr>
    </tfoot>
</table>
