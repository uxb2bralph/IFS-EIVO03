@using System.IO
@using System.Linq.Expressions

@using Model.DataEntity
@using Model.Locale
@using Model.DataEntity
@using eIVOGo.Helper
@using eIVOGo.Resource.Views.BusinessRelationship.Module

@{
    Layout = null;

    BusinessRelationship _model = (BusinessRelationship)this.Model;
    Model.Security.MembershipManagement.UserProfileMember _profile = Business.Helper.WebPageUtility.UserProfile;

    var _count = _model.Counterpart.OrganizationBranch.Count;

    IEnumerable<OrganizationBranch> items = _model.Counterpart.OrganizationBranch;

    if (_count > 0)
    {
        if (ViewBag.ByBranchNo != null)
        {
            String branchNo = (String)ViewBag.ByBranchNo;
            items = items.Where(i => i.BranchNo == branchNo);
        }
    }
}

@foreach (var item in items)
{
    <tr>
        <td>@(_model.BusinessMaster.CompanyName)</td>
        <td>@(item.BranchName)</td>
        <td>@(_model.Counterpart.ReceiptNo)</td>
        <td>@(_model.BusinessType.Business)</td>
        <td>@(item.ContactEmail)</td>
        <td>@(item.Addr)</td>
        <td>@(item.Phone)</td>
        <td>@(item.BranchNo)</td>
        <td>
            @(_model.CurrentLevel.HasValue ? _model.LevelExpression.Expression : DataItem.已啟用)
            <br />
            @(_model.BusinessID == (int)Naming.InvoiceCenterBusinessType.銷項 && _model.Counterpart.OrganizationStatus.Entrusting == true ? DataItem.自動接收 : null)
            <br />
            @(_model.Counterpart.OrganizationStatus.EntrustToPrint.HasValue ? (_model.Counterpart.OrganizationStatus.EntrustToPrint == true ? DataItem.主動列印 : @DataItem.停用列印) : @DataItem.未設定)
        </td>
        <td>
            <div class="btn-group dropdown" data-toggle="dropdown">
                <button class="btn bg-color-blueLight" data-toggle="dropdown" aria-expanded="false">@DataItem.請選擇功能</button>
                <button class="btn bg-color-blueLight dropdown-toggle" data-toggle="dropdown" aria-expanded="true"><span class="caret"></span></button>
                <ul class="dropdown-menu">
                    <li><a class="btn" onclick="uiInquireBusiness.edit(@(_model.RelativeID));">@DataItem.編輯</a></li>
                    @if (_model.CurrentLevel == (int)Naming.MemberStatusDefinition.Mark_To_Delete)
                    {
                        <li><a class="btn" onclick="uiInquireBusiness.activate(@(_model.BusinessID),@(_model.MasterID),@(_model.RelativeID));">@DataItem.啟用</a></li>
                    }
                    else
                    {
                        <li><a class="btn" onclick="uiInquireBusiness.deactivate(@(_model.BusinessID),@(_model.MasterID),@(_model.RelativeID));">@DataItem.停用</a></li>
                    }
                    @if (_model.Counterpart.OrganizationStatus.Entrusting != true)
                    {
                        <li><a class="btn" onclick="uiInquireBusiness.entrusting(@(_model.BusinessID),@(_model.MasterID),@(_model.RelativeID),true);">@DataItem.設定自動接收</a></li>
                    }
                    else
                    {
                        <li><a class="btn" onclick="uiInquireBusiness.entrusting(@(_model.BusinessID),@(_model.MasterID),@(_model.RelativeID),false);">@DataItem.停用自動接收</a></li>
                    }
                    @if (_model.Counterpart.OrganizationStatus.EntrustToPrint != true)
                    {
                        <li><a class="btn" onclick="uiInquireBusiness.entrustToPrint(@(_model.BusinessID),@(_model.MasterID),@(_model.RelativeID),true);">@DataItem.啟用列印</a></li>
                    }
                    else
                    {
                        <li><a class="btn" onclick="uiInquireBusiness.entrustToPrint(@(_model.BusinessID),@(_model.MasterID),@(_model.RelativeID),false);">@DataItem.停用列印</a></li>
                    }
                    <li><a class="btn" onclick="uiInquireBusiness.deleteItem(@(_model.BusinessID),@(_model.MasterID),@(_model.RelativeID));">@DataItem.刪除</a></li>
                    <li><a class="btn" onclick="uiInquireBusiness.inquireUser(@(_model.RelativeID));">@DataItem.管理使用者</a></li>
                </ul>
            </div>
        </td>
    </tr>
}
@if (_count == 0)
{
    <tr>
        <td>@(_model.BusinessMaster.CompanyName)</td>
        <td>@(_model.Counterpart.CompanyName)</td>
        <td>@(_model.Counterpart.ReceiptNo)</td>
        <td>@(_model.BusinessType.Business)</td>
        <td>@(_model.Counterpart.ContactEmail)</td>
        <td>@(_model.Counterpart.Addr)</td>
        <td>@(_model.Counterpart.Phone)</td>
        <td></td>
        <td>
            @(_model.CurrentLevel.HasValue ? _model.LevelExpression.Expression : @DataItem.已啟用)
            <br />
            @(_model.BusinessID == (int)Naming.InvoiceCenterBusinessType.銷項 && _model.Counterpart.OrganizationStatus.Entrusting == true ? @DataItem.自動接收 : null)
            <br />
            @(_model.Counterpart.OrganizationStatus.EntrustToPrint.HasValue ? (_model.Counterpart.OrganizationStatus.EntrustToPrint == true ? @DataItem.主動列印 : @DataItem.停用列印) : @DataItem.未設定)
        </td>
        <td>
            <div class="btn-group dropdown" data-toggle="dropdown">
                <button class="btn bg-color-blueLight" data-toggle="dropdown" aria-expanded="false">@DataItem.請選擇功能</button>
                <button class="btn bg-color-blueLight dropdown-toggle" data-toggle="dropdown" aria-expanded="true"><span class="caret"></span></button>
                <ul class="dropdown-menu">
                    <li><a class="btn" onclick="uiInquireBusiness.edit(@(_model.RelativeID));">@DataItem.編輯</a></li>
                    @if (_model.CurrentLevel == (int)Naming.MemberStatusDefinition.Mark_To_Delete)
                    {
                        <li><a class="btn" onclick="uiInquireBusiness.activate(@(_model.BusinessID),@(_model.MasterID),@(_model.RelativeID));">@DataItem.啟用</a></li>
                    }
                    else
                    {
                        <li><a class="btn" onclick="uiInquireBusiness.deactivate(@(_model.BusinessID),@(_model.MasterID),@(_model.RelativeID));">@DataItem.停用</a></li>
                    }
                    @if (_model.Counterpart.OrganizationStatus.Entrusting != true)
                    {
                        <li><a class="btn" onclick="uiInquireBusiness.entrusting(@(_model.BusinessID),@(_model.MasterID),@(_model.RelativeID),true);">@DataItem.設定自動接收</a></li>
                    }
                    else
                    {
                        <li><a class="btn" onclick="uiInquireBusiness.entrusting(@(_model.BusinessID),@(_model.MasterID),@(_model.RelativeID),false);">@DataItem.停用自動接收</a></li>
                    }
                    @if (_model.Counterpart.OrganizationStatus.EntrustToPrint != true)
                    {
                        <li><a class="btn" onclick="uiInquireBusiness.entrustToPrint(@(_model.BusinessID),@(_model.MasterID),@(_model.RelativeID),true);">@DataItem.啟用列印</a></li>
                    }
                    else
                    {
                        <li><a class="btn" onclick="uiInquireBusiness.entrustToPrint(@(_model.BusinessID),@(_model.MasterID),@(_model.RelativeID),false);">@DataItem.停用列印</a></li>
                    }
                    <li><a class="btn" onclick="uiInquireBusiness.deleteItem(@(_model.BusinessID),@(_model.MasterID),@(_model.RelativeID));">@DataItem.刪除</a></li>
                    <li><a class="btn" onclick="uiInquireBusiness.inquireUser(@(_model.RelativeID));">@DataItem.管理使用者</a></li>
                </ul>
            </div>
        </td>
    </tr>
}
