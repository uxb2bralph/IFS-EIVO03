@using System.IO
@using System.Linq.Expressions


@using eIVOGo.Helper
@using Model.Locale
@using eIVOGo.Models.ViewModel
@using Model.Models.ViewModel
@using Model.DataEntity
@using eIVOGo.Controllers
@using eIVOGo.Resource.Views.BusinessRelationship.Module
@using eIVOGo.Resource.Views.Common.Enum

@{
    var FieldClass = "form-control";

    ModelSource<InvoiceItem> models = ((SampleController<InvoiceItem>)ViewContext.Controller).DataSource;
    Model.Security.MembershipManagement.UserProfileMember _profile = Business.Helper.WebPageUtility.UserProfile;
    BusinessRelationshipQueryViewModel _viewModel = (BusinessRelationshipQueryViewModel)ViewBag.ViewModel;

    //營業人類別下拉選單
    string[] enumList = Enum.GetNames(typeof(Naming.InvoiceCenterBusinessQueryType));
    var _items = new Dictionary<string, string>();

    foreach (string item in enumList)
    {
        var name = item;

        switch (item)
        {
            case "銷項":
                name = InvoiceCenterBusinessQueryType.銷項;
                break;
            case "進項":
                name = InvoiceCenterBusinessQueryType.進項;
                break;
        }

        _items.Add(((int)Enum.Parse(typeof(Naming.InvoiceCenterBusinessQueryType), item)).ToString(), name);

    }

    EnumSelectorViewModel enumSelectorViewModel = new EnumSelectorViewModel
    {
        FieldName = "BusinessType",
        OptionItems = _items,
        SelectorIndication = InvoiceCenterBusinessQueryType.全部,
        FieldClass = "form-control"
    };
}

@{ Html.RenderPartial("~/Views/SiteAction/FunctionTitleBar.ascx", MaintainBusinessRelationship.相對營業人資料維護);}

<table class="top_table" border="0" cellspacing="0" cellpadding="0" width="100%">
    <tbody>
        <tr>
            <td>
                @if (_profile.IsSystemAdmin())
                {
                    <div class="btn-group dropdown" data-toggle="dropdown">
                        <button class="btn bg-color-blueLight" data-toggle="dropdown" aria-expanded="false">@MaintainBusinessRelationship.匯入相對營業人</button>
                        <button class="btn bg-color-blueLight dropdown-toggle" data-toggle="dropdown" aria-expanded="true"><span class="caret"></span></button>
                        <ul class="dropdown-menu" style="min-width:auto;">
                            <li><button type="button" class="btn" onclick="window.location.href='@(Url.Action("ImportCounterpartBusiness", "BusinessRelationship"))';">@MaintainBusinessRelationship.匯入分店相對營業人</button></li>
                            <li><button class="btn" onclick="window.location.href='@(Url.Action("ImportCounterpartBusinessXml", "BusinessRelationship"))';">@MaintainBusinessRelationship.匯入商務關係相對營業人</button></li>
                        </ul>
                    </div>
                }
                else
                {
                    <button type="button" class="btn" onclick="window.location.href='@(Url.Action("ImportCounterpartBusiness", "BusinessRelationship"))';">@MaintainBusinessRelationship.匯入分店相對營業人</button>
                }
            </td>
        </tr>
    </tbody>
</table>
<div class="border_gray">
    <!--表格 開始-->
    <table class="left_title" border="0" cellspacing="0" cellpadding="0" width="100%" id="queryArea">
        <tbody>
            <tr>
                <th class="Head_style_a" colspan="2">
                    @MaintainBusinessRelationship.查詢條件
                </th>
            </tr>
            @if (_profile.IsSystemAdmin())
            {
                <tr>
                    <th>
                        @MaintainBusinessRelationship.集團成員
                    </th>
                    <td class="tdleft">
                        @{ Html.RenderPartial("~/Views/BusinessRelationship/Module/GroupMemberSelector.cshtml",
                        new EnumSelectorViewModel
                        {
                            SelectorIndication = InvoiceCenterBusinessQueryType.全部,
                            FieldName = "CompanyID",
                            FieldClass = "form-control"
                        });}
                    </td>
                </tr>
            }
            <tr>
                <th width="120">
                    @MaintainBusinessRelationship.營業人統編
                </th>
                <td class="tdleft">
                    <input name="ReceiptNo" type="text" />
                    &nbsp;
                </td>
            </tr>
            <tr>
                <th width="120">
                    <span class="tdleft">@MaintainBusinessRelationship.營業人名稱</span>
                </th>
                <td class="tdleft">
                    <input name="CompanyName" type="text" />
                    &nbsp;
                </td>
            </tr>
            <tr>
                <th width="120">
                    <span class="tdleft">@MaintainBusinessRelationship.店號</span>
                </th>
                <td class="tdleft">
                    <input name="branchNo" type="text" />
                    &nbsp;
                </td>
            </tr>
            <tr>
                <th width="120">
                    @MaintainBusinessRelationship.營業人狀態
                </th>
                <td class="tdleft">
                    <select name="CompanyStatus" class="@(FieldClass)">
                        <option value="">@MaintainBusinessRelationship.全部</option>
                        <option value="1103">@MaintainBusinessRelationship.已啟用</option>
                        <option value="1101">@MaintainBusinessRelationship.已停用</option>
                    </select>
                </td>
            </tr>
            <tr>
                <th width="120">
                    @MaintainBusinessRelationship.營業人類別
                </th>
                <td class="tdleft">
                    @{Html.RenderPartial("~/Views/Common/Module/EnumSelect.cshtml", enumSelectorViewModel);}
                </td>
            </tr>
            <tr>
                <th width="120">
                    @MaintainBusinessRelationship.自動接收
                </th>
                <td class="tdleft">
                    <select name="Entrusting" class="@(FieldClass)">
                        <option value="">@MaintainBusinessRelationship.全部</option>
                        <option value="True">@MaintainBusinessRelationship.已啟用</option>
                        <option value="False">@MaintainBusinessRelationship.已停用</option>
                    </select>
                </td>
            </tr>
            <tr>
                <th width="120">
                    @MaintainBusinessRelationship.主動列印
                </th>
                <td class="tdleft">
                    <select name="EntrustToPrint" class="@(FieldClass)">
                        <option value="">@MaintainBusinessRelationship.全部</option>
                        <option value="True">@MaintainBusinessRelationship.已啟用</option>
                        <option value="False">@MaintainBusinessRelationship.已停用</option>
                    </select>
                </td>
            </tr>
        </tbody>
    </table>
    <!--表格 結束-->
</div>
<table border="0" cellspacing="0" cellpadding="0" width="100%" class="queryAction">
    <tbody>
        <tr>
            <td class="Bargain_btn">
                <button type="button" onclick="uiInquireBusiness.inquireBusiness();">@MaintainBusinessRelationship.查詢</button>
            </td>
        </tr>
    </tbody>
</table>
<script>
    var uiInquireBusiness;
    $(function () {

        uiInquireBusiness = {
            $result: null,
            commitItem: function (value) {
                alert('test');
                var event = event || window.event;
                var $tr = $(event.target).closest('tr');
                $.post('@(Url.Action("CommitItem","BusinessRelationship"))', $.param($tr.find('input,select,textarea')), function (data) {
                    if (data) {
                        var $data = $(data);
                        if ($data.is('tr')) {
                            $tr.before($data);
                            if (value) {
                                alert('@MaintainBusinessRelationship.資料已更新__');
                                $tr.remove();
                            }
                        } else {
                            $('body').append($data);
                            $data.remove();
                        }
                    }
                });
            },
            edit: function (value) {
                actionHandler('@(VirtualPathUtility.ToAbsolute("~/Helper/EditCompany.aspx"))',
                    { 'companyID': value },
                    function () {
                        uiInquireBusiness.inquireBusiness();
                    }, 800, 560);
            },
            inquireBusiness: function (pageNum, onPaging) {
                if (pageNum) {
                    $('input[name="pageIndex"]').val(pageNum);
                } else {
                    $('input[name="sort"]').remove();
                }
                var $formData = $('#queryArea').find('input,select,textarea').serializeObject();
                $.ajax({
                type: "POST",
                    url: '@Url.Action("InquireBusinessRelationship","BusinessRelationship", new { resultAction = ViewBag.ResultAction, obj="$formData"})',
                beforeSubmit: function () {
                        showLoading();
                    },
                data: $formData,
                dataType: "text",
                    success: function (data) {
                        hideLoading();
                        if (data) {
                            if (onPaging) {
                                onPaging(data);
                            } else {
                                if (uiInquireBusiness.$result)
                                    uiInquireBusiness.$result.remove();
                                uiInquireBusiness.$result = $(data);
                                $('.queryAction').after(uiInquireBusiness.$result);
                            }
                        }
                    },
                    error: function () {
                    }
                });


            },
            deleteItem: function (businessID, masterID, relativeID) {
                if (confirm('@MaintainBusinessRelationship.確認刪除此營業人關係_')) {
                    var event = event || window.event;
                    var $tr = $(event.target).closest('tr');
                    $.post('@(Url.Action("DeleteItem","BusinessRelationship"))', { businessID: businessID, masterID: masterID, relativeID: relativeID }, function (data) {
                        if (data.result) {
                            alert('@MaintainBusinessRelationship.資料已刪除__')
                            $tr.remove();
                        } else {
                            alert(data.message);
                        }
                    });

                }
            },
            entrustToPrint: function (businessID, masterID, relativeID, onoff) {
                if (confirm('@MaintainBusinessRelationship.確認停用列印_')) {
                    var event = event || window.event;
                    var $tr = $(event.target).closest('tr');
                    $.post('@(Url.Action("SetEntrustToPrint","BusinessRelationship"))', { businessID: businessID, masterID: masterID, relativeID: relativeID, status: onoff }, function (data) {
                        if (data) {
                            var $data = $(data);
                            if ($data.is('tr')) {
                                $tr.before($data);
                                alert('@MaintainBusinessRelationship.資料已更新__');
                                $tr.remove();
                            } else {
                                $('body').append($data);
                                $data.remove();
                            }
                        }
                    });

                }
            },
            entrusting: function (businessID, masterID, relativeID, onoff) {
                if (confirm('@MaintainBusinessRelationship.確認啟用此營業人自動接收_')) {
                    var event = event || window.event;
                    var $tr = $(event.target).closest('tr');
                    $.post('@(Url.Action("SetEntrusting","BusinessRelationship"))', { businessID: businessID, masterID: masterID, relativeID: relativeID, status: onoff }, function (data) {
                        if (data) {
                            var $data = $(data);
                            if ($data.is('tr')) {
                                $tr.before($data);
                                alert('@MaintainBusinessRelationship.資料已更新__');
                                $tr.remove();
                            } else {
                                $('body').append($data);
                                $data.remove();
                            }
                        }
                    });

                }
            },
            activate: function (businessID, masterID, relativeID) {
                if (confirm('@MaintainBusinessRelationship.確認啟用此營業人_')) {
                    var event = event || window.event;
                    var $tr = $(event.target).closest('tr');
                    $.post('@(Url.Action("Activate","BusinessRelationship"))', { businessID: businessID, masterID: masterID, relativeID: relativeID }, function (data) {
                        if (data) {
                            var $data = $(data);
                            if ($data.is('tr')) {
                                $tr.before($data);
                                alert('@MaintainBusinessRelationship.資料已更新__');
                                $tr.remove();
                            } else {
                                $('body').append($data);
                                $data.remove();
                            }
                        }
                    });

                }
            },
            deactivate: function (businessID, masterID, relativeID) {
                if (confirm('@MaintainBusinessRelationship.確認停用此營業人_')) {
                    var event = event || window.event;
                    var $tr = $(event.target).closest('tr');
                    $.post('@(Url.Action("Deactivate","BusinessRelationship"))', { businessID: businessID, masterID: masterID, relativeID: relativeID }, function (data) {
                        if (data) {
                            var $data = $(data);
                            if ($data.is('tr')) {
                                $tr.before($data);
                                alert('@MaintainBusinessRelationship.資料已更新__');
                                $tr.remove();
                            } else {
                                $('body').append($data);
                                $data.remove();
                            }
                        }
                    });
                }
            },

            inquireUser: function (value) {
                $.post('@(Url.Action("AccountIndex","Account",new { showTab = true, roleID = (int)Naming.RoleQueryDefinition.分店相對營業人 }))', { 'sellerID': value }, function (data) {
                    $global.createTab('@("listUser"+DateTime.Now.Ticks)', '@MaintainBusinessRelationship.使用者管理', data, true);
                });
            },
        };
    });
</script>
