@using System.IO
@using System.Linq.Expressions


@using eIVOGo.Helper
@using Model.Locale
@using eIVOGo.Models.ViewModel
@using Model.Models.ViewModel
@using Model.DataEntity
@using eIVOGo.Controllers
@using eIVOGo.Resource.Views.BusinessRelationship.Module

@{
    EnumSelectorViewModel enumSelectorViewModel = (EnumSelectorViewModel)this.Model;

    ModelSource<InvoiceItem> models;

    IEnumerable<Organization> _groupMembers;
    Model.Security.MembershipManagement.UserProfileMember _profile;
    var _items = new Dictionary<string, string>();

    models = ((SampleController<InvoiceItem>)ViewContext.Controller).DataSource;
    _profile = Business.Helper.WebPageUtility.UserProfile;

    if (_profile.IsSystemAdmin())
    {
        _groupMembers = models.GetTable<EnterpriseGroupMember>().Select(o => o.CompanyID)
                .Distinct().Join(models.GetTable<Organization>(), d => d, o => o.CompanyID, (d, o) => o).OrderBy(o => o.ReceiptNo);

    }
    else
    {
        _groupMembers = models.GetTable<EnterpriseGroupMember>()
                .Where(o => o.CompanyID == _profile.CurrentUserRole.OrganizationCategory.CompanyID)
                .Select(o => o.CompanyID)
                .Join(models.GetTable<Organization>(), d => d, o => o.CompanyID, (d, o) => o).OrderBy(o => o.ReceiptNo);
    }

    foreach (var item in _groupMembers)
    {
        _items.Add(item.CompanyID.ToString(), $"{item.ReceiptNo} {item.CompanyName}");
    }

    enumSelectorViewModel.OptionItems = _items;
}

@{Html.RenderPartial("~/Views/Common/Module/EnumSelect.cshtml", enumSelectorViewModel);}

