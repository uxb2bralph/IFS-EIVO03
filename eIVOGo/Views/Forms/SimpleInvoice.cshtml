
@using System.IO
@using System.Linq.Expressions
@using eIVOGo.Helper
@using Model.Locale
@using eIVOGo.Models.ViewModel
@using Model.Models.ViewModel
@using Model.DataEntity
@using eIVOGo.Controllers
@using eIVOGo.Resource.Views.Common.Enum
@using B2BInvoice = eIVOGo.Resource.Views.Forms.B2BInvoice
@using res = eIVOGo.Resource.Views.Forms.SimpleInvoice

@{

    InvoiceViewModel _viewModel;


    ViewBag.ActionName = "首頁 > 電子發票開立";
    _viewModel = (InvoiceViewModel)ViewBag.ViewModel;

    //發票類別下拉選單
    string[] enumList = Enum.GetNames(typeof(Naming.InvoiceTypeDefinition));
    var _items = new Dictionary<string, string>();

    foreach (string item in enumList)
    {
        var name = item;

        switch (item)
        {
            case "一般稅額計算之電子發票":
                name = InvoiceTypeDefinition.一般稅額計算之電子發票;
                break;
            case "特種稅額計算之電子發票":
                name = InvoiceTypeDefinition.特種稅額計算之電子發票;
                break;
        }

        _items.Add(((int)Enum.Parse(typeof(Naming.InvoiceTypeDefinition), item)).ToString(), name);

    }

    EnumSelectorViewModel enumSelectorViewModel = new EnumSelectorViewModel
    {
        FieldName = "InvoiceType",
        OptionItems = _items,
        FieldClass = "form-control"
    };
}

@{ Html.RenderPartial("~/Views/SiteAction/FunctionTitleBar.cshtml", @B2BInvoice.電子發票開立);}

<form role="form" method="post">
