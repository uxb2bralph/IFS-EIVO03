                    <a class="btn" onclick="uiInvoice.sum();">@B2BInvoice.小計</a>
                    <a class="btn" onclick="uiInvoice.commit(true);">@B2BInvoice.發票預覽</a>
                    <a class="btn" onclick="uiInvoice.commit();">@B2BInvoice.發票開立</a>
