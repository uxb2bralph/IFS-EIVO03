

<script>
    $(function () {
        var $postForm;
        if (!window.uiWinningNo) {
            window.uiWinningNo = {};
        }
        uiWinningNo.match = function () {
            var year = $('input[name="Year"]').val();
            var periodno = $('input[name="PeriodNo"]').val();
            var sort = $('input[name="sort"]').serializeObject().sort;
            var _Object = { Year: year, PeriodNo: periodno, Sort: sort };
            $.ajax({
                type: "POST",
                url: '@Url.Action("MatchWinningInvoiceNo", "WinningNumber", new { resultAction = ViewBag.ResultAction, obj="_Object"})',
                beforeSubmit: function () {
                    showLoading();
                },    
                data: _Object,
                dataType: "text",
                success: function (data) {
                    if (data) {
                        var $data = $(data);
                        $('body').append($data);
                        $data.remove();
                    }
                    hideLoading();
                },
                error: function (error) {
                    hideLoading();
                }
            });
        };
        uiWinningNo.resetWinning = function () {
            var year = $('input[name="Year"]').val();
            var periodno = $('input[name="PeriodNo"]').val();
            var sort = $('input[name="sort"]').serializeObject().sort;
            var _Object = { Year: year, PeriodNo: periodno, Sort: sort };
            $.ajax({
                type: "POST",
                url: '@Url.Action("ClearWinningInvoiceNo", "WinningNumber", new { resultAction = ViewBag.ResultAction, obj="_Object"})',
                beforeSubmit: function () {
                    showLoading();
                },    
                data: _Object,
                dataType: "text",
                success: function (data) {
                    if (data) {
                        var $data = $(data);
                        $('body').append($data);
                        $data.remove();
                    }
                    hideLoading();
                },
                error: function (error) {
                    hideLoading();
                }
            });
        };        
    });
</script>


