@using Model.DataEntity
@using res=eIVOGo.Resource.Views.InvoiceNo.Module.IntervalItemList

@{
    IEnumerable<InvoiceNoInterval> _items;
    _items = (IEnumerable<InvoiceNoInterval>)this.Model;
}

<table class="table01 itemList">
    <thead>
        <tr>
            <th style="min-width: 100px">@res.發票年度</th>
            <th style="min-width: 100px">@res.發票期別</th>
            <th style="min-width: 80px">@res.字軌</th>
            <th style="min-width: 160px">@res.發票號碼起</th>
            <th style="min-width: 160px">@res.發票號碼迄</th>
            <th style="min-width: 160px">@res.配號總數_剩餘</th>
            <th>@res.已配號</th>
            <th style="min-width: 150px">@res.管理</th>
        </tr>
    </thead>
    <tbody>
        @{ int idx = 0;}
        @foreach (var item in _items)
        {
            idx++;
            Html.RenderPartial("~/Views/InvoiceNo/Module/DataItem.cshtml", item);
        }@{ Html.RenderPartial("~/Views/InvoiceNo/Module/AddItem.cshtml");}

    </tbody>
    <tfoot>
        <tr>
            <td colspan="10">&nbsp;</td>
        </tr>
    </tfoot>
</table>
