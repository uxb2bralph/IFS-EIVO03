@using System.IO
@using System.Linq.Expressions
@using eIVOGo.Helper
@using Model.Locale
@using eIVOGo.Models.ViewModel
@using Model.Models.ViewModel
@using Model.DataEntity
@using eIVOGo.Controllers

@{
    ModelSource<InvoiceItem> models;
    InquireNoIntervalViewModel _viewModel;
    IEnumerable<InvoiceTrackCode> _items;
    EnumSelectorViewModel enumSelectorViewModel = (EnumSelectorViewModel)this.Model;

    models = ((SampleController<InvoiceItem>)ViewContext.Controller).DataSource;
    _viewModel = (InquireNoIntervalViewModel)ViewBag.ViewModel;
    if (_viewModel != null)
    {
        _items = models.GetTable<InvoiceTrackCode>().Where(t => t.Year == _viewModel.Year && t.PeriodNo == _viewModel.PeriodNo);
    }
    else
    {
        _items = models.GetTable<InvoiceTrackCode>().Where(t => false);
    }

    var _options = new Dictionary<string, string>();
    foreach (var item in _items)
    {
        _options.Add(item.TrackID.ToString(), item.TrackCode);
    }

    enumSelectorViewModel.OptionItems = _options;
}

@{Html.RenderPartial("~/Views/Common/Module/EnumSelect.cshtml", enumSelectorViewModel);}