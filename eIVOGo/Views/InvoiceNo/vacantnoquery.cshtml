    </table>
    <!--表格 結束-->
</div>

<!--按鈕-->
<table border="0" cellspacing="0" cellpadding="0" width="100%" class="queryAction">
    <tbody>
        <tr>
            <td class="Bargain_btn">
                <button type="button" onclick="uiVacantNoQuery.inquire();">@res.查詢</button>&nbsp;&nbsp;
                <button type="button" onclick="uiVacantNoQuery.process();">@res.重新整理空白發票</button>
            </td>
        </tr>
    </tbody>
</table>
<!--表格 開始-->
<script>
    var uiVacantNoQuery;
    $(function () {
        var $postForm;
        uiVacantNoQuery = {
            inquire: function (pageNum, onPaging) {
                if (pageNum) {
                    $('input[name="pageIndex"]').val(pageNum);
                } else {
                    $('input[name="sort"]').remove();
                }
                
                var $formData = $('#queryArea').find('input,select,textarea').serializeObject();                

                $.ajax({
                    type: "POST",
                    url: "@Url.Action("InquireVacantNo","InvoiceNo", new { obj = "$formData" })",                    
                    beforeSubmit: function () {
                        showLoading();
                    },
                    data: $formData,
                    datatype: "text",
                    success: function (data) {
                        if (data) {
                            if (onPaging) {
                                onPaging(data);
                            } else {
                                if (uiVacantNoQuery.$result)
                                    uiVacantNoQuery.$result.remove();
                                uiVacantNoQuery.$result = $(data);
                                $('.queryAction').after(uiVacantNoQuery.$result);
                            }
                        }
                        hideLoading();
                    },
                    error: function () {
                        hideLoading();
                    }
                });
            },

            download: function () {
                if ($postForm) {
                    $postForm.remove();
                }

                var $formData = $('#queryArea').find('input,select,textarea').serializeArray();

                $postForm = $('<form method="post" />').prop('action', '@(Url.Action("DownloadVacantNo","InvoiceNo"))')
                    .css('display', 'none').appendTo($('body'));

                $formData.forEach(function (item, index) {
                    $('<input type="hidden">')
                        .prop('name', item.name).prop('value', item.value)
                        .appendTo($postForm);
                });
                $postForm.submit();
                //showLoading();
            },
            downloadCsv: function () {
                if ($postForm) {
                    $postForm.remove();
                }

                var $formData = $('#queryArea').find('input,select,textarea').serializeArray();

                $postForm = $('<form method="post" />').prop('action', '@(Url.Action("DownloadVacantNoCsv","InvoiceNo"))')
                    .css('display', 'none').appendTo($('body'));

                $formData.forEach(function (item, index) {
                    $('<input type="hidden">')
                        .prop('name', item.name).prop('value', item.value)
                        .appendTo($postForm);
                });
                $postForm.submit();
                //showLoading();
            },

            process: function () {
                $('#theForm').ajaxForm({
                    url: "@(Url.Action("ProcessVacantNo","InvoiceNo"))",
                    beforeSubmit: function () {
                        showLoading();
                    },
                    success: function (data) {
                        if (data) {
                            $(data).appendTo($('body')).remove();
                        }
                        hideLoading();
                    },
                    error: function () {
                        hideLoading();
                    }
                }).submit();
            }
        };
    });
</script>


