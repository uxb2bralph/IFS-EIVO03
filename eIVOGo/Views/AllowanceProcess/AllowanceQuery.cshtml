@using System.IO
@using System.Linq.Expressions

@using eIVOGo.Helper
@using eIVOGo.Models
@using eIVOGo.Models.ViewModel
@using Model.Models.ViewModel
@using Model.DataEntity
@using Model.Helper
@using Model.Locale
@using Utility
@using Uxnet.Web.WebUI
@using res = eIVOGo.Resource.Views.AllowanceProcess.AllowanceQuery
@using invoke = eIVOGo.Resource.Views.AllowanceProcess.Module.InvokeCommitAction

@{

    InquireInvoiceViewModel _viewModel;
    _viewModel = (InquireInvoiceViewModel)ViewBag.ViewModel;
}
<!--交易畫面標題-->
@{ Html.RenderPartial("~/Views/SiteAction/FunctionTitleBar.cshtml", res.折讓證明查詢 + "／" + res.列印 + "／" + res.匯出);}

<div class="border_gray">
    <!--表格 開始-->
    <table id="queryArea" width="100%" border="0" cellpadding="0" cellspacing="0" class="left_title">
        <tr>
            <th colspan="2" class="Head_style_a">
                @res.查詢條件
            </th>
        </tr>
        @{ Html.RenderPartial("~/Views/InvoiceProcess/Module/QueryDirective.cshtml", 1);}

        <tr>
            <th>
                @res.發票類別
            </th>
            <td class="tdleft">
                <select name="ProcessType">
                    <option value="">@res.查詢全部</option>
                    <option value="@((int)Naming.InvoiceProcessType.D0401)">@res.查詢QR_Code證明聯類型</option>
                    <option value="@((int)Naming.InvoiceProcessType.B0401)">@res.查詢營業人交易類型</option>
                </select>
                @if (Request["ProcessType"] != null)
                {
                    <script>
                    $(function () {
                        $('select[name="ProcessType"]').val('@(Request["ProcessType"])');
                    });
                    </script>
                }
            </td>
        </tr>
        @{ Html.RenderAction("BySeller", "InquireInvoice", new { fieldName = "CompanyID" });}

        <tr>
            <th>
                @res.發票_折讓單號碼
            </th>
            <td class="tdleft">
                <input class="form-control" name="DataNo" type="text" />
            </td>
        </tr>
        <tr>
            <th>
                @res.買受人統編
            </th>
            <td class="tdleft">
                <input class="form-control" name="BuyerReceiptNo" type="text" />
            </td>
        </tr>
        <tr>
            <th>
                @res.買受人名稱
            </th>
            <td class="tdleft">
                <input class="form-control" name="BuyerName" type="text" />
            </td>
        </tr>
        <tr>
            <th width="20%">
                @res.日期區間
            </th>
            <td class="tdleft">
                @res.自&nbsp;<input id="DateFrom" name="DateFrom" type="text" size="10" readonly="readonly" value="" />
                &nbsp;@res.至&nbsp;
                <input id="DateTo" name="DateTo" type="text" size="10" readonly="readonly" value="" />
                <script>
                    $(function () {
                        $('#DateFrom').datepicker({ showButtonPanel: true, changeYear: true, changeMonth: true, yearRange: '2012:+1' });
                        $('#DateTo').datepicker({ showButtonPanel: true, changeYear: true, changeMonth: true, yearRange: '2012:+1' });
                    });
                </script>
            </td>
        </tr>
        <tr>
            <th>
                @res.單據狀態
            </th>
            <td class="tdleft">
                <select name="Cancelled">
                    <option value="False">@res.未作廢</option>
                    <option value="True">@res.已作廢</option>
                    <option value="">@res.全部</option>
                </select>
            </td>
        </tr>
        <tr>
            <th>
                @res.每頁資料筆數
            </th>
            <td class="tdleft">
                <input name="pageSize" type="text" value="@(Request["pageSize"] ?? Uxnet.Web.Properties.Settings.Default.PageSize.ToString())" />
            </td>
        </tr>
    </table>
    <!--表格 結束-->
</div>

<!--按鈕-->
<table border="0" cellspacing="0" cellpadding="0" width="100%" class="queryAction">
    <tbody>
        <tr>
            <td class="Bargain_btn">
                <button type="button" onclick="uiAllowanceQuery.initQuery=true;uiAllowanceQuery.inquire();">@res.查詢</button>
            </td>
        </tr>
    </tbody>
</table>
<!--表格 開始-->
<script>
    var uiAllowanceQuery;
    $(function () {
        var $postForm;
        uiAllowanceQuery = {
            inquire: function (pageNum, onPaging) {
                var $this = uiAllowanceQuery;
                var $placement = $('button:contains("@res.查詢")').closest('table');
                var $formData = $('#queryArea').find('input,select,textarea').serializeObject();

                if (isNaN(pageNum)) {
                    $formData.startQuery = true;
                    uiAllowanceQuery.pageIndex = 1;
                }
                else {
                    $formData.pageIndex = pageNum;
                    $this.pageIndex = pageNum;
                }

                if ($this.sort) {
                    $formData.Sort = $this.sort.getSort();
                }

                showLoading();

                $.post('@Html.Raw(Url.Action("Inquire","AllowanceProcess",new { resultAction = ViewBag.ResultAction }))', $formData, function (data) {

                    hideLoading();
                    if ($.isPlainObject(data)) {
                        alert(data.message);
                    } else {
                        if ($this.initQuery) {

                            if (uiAllowanceQuery.$result)
                                uiAllowanceQuery.$result.remove();
                            uiAllowanceQuery.$result = $(data).insertAfter($placement);
                            $this.initQuery = false;
                            //$this.showHeader();
                            //$this.checkColumns();
                        } else {
                            $this.paging(data);
                            //$this.checkColumns();
                        }
                    }
                });

            },
            void: function (actionTitle,commitAction) {
                showLoading();

                var $formData = $('#theForm').serializeObject();

                $formData.CommitAction = commitAction;

                $formData.ActionTitle = actionTitle;

                $.post('@Html.Raw(Url.Action("InvokeCommitAction","AllowanceProcess"))', $formData, function (data) {
                    if ($.isPlainObject(data)) {
                        hideLoading();
                        alert(data.message);
                    } else {
                        $(data).appendTo($('body'));
                    }
                });
            },
            invokeCommitAction: function (actionTitle, commitAction,msg) {                
                alert('88');
                if (!$('input[name="chkItem"]').is(':checked')) {
                    alert(msg);
                    return false;
                }

                var $formData = $('input[name="chkItem"]:checked').serializeObject();

                showLoading();
                $.post('@Html.Raw(Url.Action("VoidAllowance", "AllowanceProcess"))', $formData, function (data) {
                    hideLoading();
                    if ($.isPlainObject(data)) {
                        alert(data.message);
                    } else {
                        $(data).appendTo($('body')).remove();
                    }
                });
            },
            print: function (style) {
                if (!$('input[name="chkItem"]').is(':checked')) {
                    alert('@res.請選擇列印資料__');
                    return false;
                }

                var $formData = $('#theForm').serializeObject();
                $formData.paperStyle = style;
                //$formData.processType = processType;

                showLoading();
                $.post('@Html.Raw(Url.Action("Print","AllowanceProcess",new { _viewModel.ProcessType }))', $formData, function (data) {
                    hideLoading();
                    if ($.isPlainObject(data)) {
                        alert(data.message);
                    } else {
                        if (data) {
                            var $data = $(data);
                            $data.dialog();
                            $data.find('a').on('click', function (evt) {
                                $data.dialog('close');
                            });
                        }
                    }
                });
            },

            notify: function () {
                if (!$('input[name="chkItem"]').is(':checked')) {
                    alert('@res.請選擇待重送資料__');
                    return false;
                }

                var $formData = $('input[name="chkItem"]:checked').serializeObject();
                $formData.cancellation = $('#queryArea select[name="Cancelled"]').val();

                showLoading();
                $.post('@Html.Raw(Url.Action("IssueAllowanceNotice", "AllowanceProcess"))', $formData, function (data) {
                    hideLoading();
                    if ($.isPlainObject(data)) {
                        alert(data.message);
                    } else {
                        $(data).appendTo($('body')).remove();
                    }
                });

            },

            download: function () {
                if ($postForm) {
                    $postForm.remove();
                }

                var $formData = $('#queryArea').find('input,select,textarea').serializeArray();

                $postForm = $('<form method="post" />').prop('action', '@Html.Raw(Url.Action("CreateXlsx","AllowanceProcess"))')
                    .css('display', 'none').appendTo($('body'));

                $formData.forEach(function (item, index) {
                    $('<input type="hidden">')
                        .prop('name', item.name).prop('value', item.value)
                        .appendTo($postForm);
                });
                $postForm.submit();
                //showLoading();
            },
        };
    });
</script>


