
@using System.IO
@using System.Linq.Expressions

@using eIVOGo.Helper
@using eIVOGo.Models
@using eIVOGo.Models.ViewModel
@using Model.Models.ViewModel
@using eIVOGo.Controllers
@using Model.DataEntity
@using Model.Helper
@using Model.Locale
@using Utility
@using Uxnet.Web.WebUI
@using res=eIVOGo.Resource.Views.AllowanceProcess.Module.DoVoidAllowance

@{
    ModelSource<InvoiceItem> models;
    InquireInvoiceViewModel _viewModel;
    models = ((SampleController<InvoiceItem>)ViewContext.Controller).DataSource;
    _viewModel = ViewBag.ViewModel as InquireInvoiceViewModel;  

    _viewModel.ActionTitle = res.作廢折讓;
    _viewModel.CommitAction = "VoidAllowance";
    String _viewID = $"btn{DateTime.Now.Ticks}";
}

@if (_viewModel != null)
{
    <button type="button" class="btn" id="@(_viewID)" name="btnVoid" onclick="uiAllowanceQuery.void('@_viewModel.ActionTitle','@_viewModel.CommitAction');">@(_viewModel.ActionTitle)</button>
    
}



