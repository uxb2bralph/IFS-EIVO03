
@using System.Linq
@using System.IO
@using System.Linq.Expressions

@using Newtonsoft.Json
@using eIVOGo.Controllers
@using eIVOGo.Helper
@using eIVOGo.Models
@using eIVOGo.Models.ViewModel
@using Model.Models.ViewModel
@using Model.DataEntity
@using Model.Helper
@using Model.Locale
@using Utility
@using Uxnet.Web.WebUI
@using res=eIVOGo.Resource.Views.AllowanceProcess.Module.InvokeCommitAction

@{ 
    InquireInvoiceViewModel _viewModel=(InquireInvoiceViewModel)this.Model;

    //string msg = "¨∞§∞ªÚ";// $"{res.Ω–øÔæ‹´›} {_viewModel.ActionTitle} {res.∏ÍÆ∆}!!";
}

    <script>
    $(function () {
        
        if (!$('input[name="chkItem"]').is(':checked')) {
            alert('@Html.Raw($"Ω–øÔæ‹´›{_viewModel.ActionTitle}∏ÍÆ∆!!")');
            return false;
        }

        var $formData = $('input[name="chkItem"]:checked').serializeObject();

        showLoading();
        $.post('@Html.Raw(Url.Action(_viewModel.CommitAction, "AllowanceProcess"))', $formData, function (data) {
            hideLoading();
            if ($.isPlainObject(data)) {
                alert(data.message);
            } else {
                $(data).appendTo($('body')).remove();
            }
        });
    });
    </script>

