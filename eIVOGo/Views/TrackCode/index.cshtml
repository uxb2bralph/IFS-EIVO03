
@using System.IO
@using System.Linq.Expressions

@using eIVOGo.Helper
@using eIVOGo.Models
@using Model.DataEntity
@using Model.Helper
@using Model.Locale
@using Utility
@using Uxnet.Web.WebUI
@using eIVOGo.Helper
@using eIVOGo.Resource.Views.Common
@using eIVOGo.Resource.Views.TrackCode
@model Model.Models.ViewModel.TrackCodeQueryViewModel

@{
    Layout = "~/Views/Template/MvcMainPage.cshtml";

    ViewBag.ActionName = TreeView.首頁___系統管理維護;

    //IEnumerable<InvoiceTrackCode> _model = (IEnumerable<InvoiceTrackCode>)this.Model;
    var _model = this.Model;

    int _pageSize = 0;

    if (ViewBag.PageSize != null)
    {
        _pageSize = (int)ViewBag.PageSize;
    }

    var recordCount = 0;
    int? Year;
    int? PeriodNo = 0;

    if (_model != null && _model.Results != null)
    {
        recordCount = _model.Results.Count();
        Year = _model.Year;
        PeriodNo = _model.PeriodNo;
    }
}

@{Html.RenderPartial("~/Views/TrackCode/TrackCodeQuery.cshtml");}

<input type="hidden" name="PeriodNo" value=@(PeriodNo) />

@{Html.HiddenFor(model => model.PeriodNo);}
@{Html.HiddenFor(model => model.Year);}

@if (_model != null && _model.Year != null)
{
    Html.RenderPartial("~/Views/SiteAction/FunctionTitleBar.ascx", @Index.查詢結果);

    <div class="border_gray" style="overflow-x: auto; max-width: 1024px;">

        @if (_model != null && recordCount > 0 && ViewBag.PageSize != null)
        {
            { Html.RenderPartial("~/Views/TrackCode/Module/ItemList.cshtml", _model); }

            <input type="hidden" name="pageIndex" />

            <nav aria-label="Page navigation">
                <ul class="pagination" id="itemPagination"></ul>
            </nav>
            <script>
                $(function () {
                    var obj = $('#itemPagination').twbsPagination({
                totalPages: @((recordCount+_pageSize-1) / _pageSize),
                        totalRecordCount: +@(recordCount),
                        displayTotalPages: '@Index.總頁數',
                        displayTotalRecordCount:'@Index.總筆數',
                                visiblePages: 10,
                                first: '@Index.最前',
                                prev: '@Index.上頁',
                                next: '@Index.下頁',
                                last: '@Index.最後',
                                initiateStartPageClick: false,
                                onPageClick: function (event, page) {
                    uiTrackCodeQuery.inquire(page,function(data){
                        var $node = $('.itemList').next();
                                        $('.itemList').remove();
                        $node.before(data);

                    });

                        }

                    });

                });

            </script>

            if (ViewBag.ResultAction != null)
            {
                Html.RenderPartial((String)ViewBag.ResultAction);
            }

        }
        else
        {
            <font color="red">@Index.查無資料!!</font>
            { Html.RenderPartial("~/Views/TrackCode/Module/ItemList.cshtml", _model.Results); }

        }
    </div>
}
@*@if (this.Model != null)
    { Html.RenderPartial("~/Views/TrackCode/QueryResult.cshtml"); }*@

