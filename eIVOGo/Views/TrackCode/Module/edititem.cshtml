@using Model.DataEntity
@using Model.Locale
@using eIVOGo.Resource.Views.TrackCode.Module

@{
    InvoiceTrackCode _model = _model = (InvoiceTrackCode)this.Model;
}

    <tr>
        <td>@(_model.Year - 1911)<input name="Year" type="hidden" value="@(_model.Year)" /></td>
        <td>@(String.Format("{0:00}", _model.PeriodNo * 2 - 1))~@(String.Format("{0:00}", _model.PeriodNo * 2))@(EditItem.月)</td>
        <td><input type="text" name="TrackCode" class="form-control" placeholder="@(EditItem.請輸入字軌)" value="@(_model.TrackCode)" data-role="edit" /></td>
        <td>
            <select name="InvoiceType">
                <option value="7" @(_model.InvoiceType == (byte)Naming.InvoiceTypeDefinition.一般稅額計算之電子發票 ? "selected" : null)>@(EditItem.一般稅額計算之電子發票)</option>
                <option value="8" @(_model.InvoiceType == (byte)Naming.InvoiceTypeDefinition.特種稅額計算之電子發票 ? "selected" : null)>@(EditItem.特種稅額計算之電子發票)</option>
            </select>
        </td>
        <td>
            <div class="btn-group dropdown" data-toggle="dropdown">
                <button class="btn bg-color-blueLight" data-toggle="dropdown" aria-expanded="false">@(EditItem.請選擇功能)</button>
                <button class="btn bg-color-blueLight dropdown-toggle" data-toggle="dropdown" aria-expanded="true"><span class="caret"></span></button>
                <ul class="dropdown-menu">
                    <li><a class="btn" onclick="uiTrackCodeQuery.commitItem(@(_model.TrackID));">@(EditItem.確定)</a></li>
                    <li><a class="btn" onclick="uiTrackCodeQuery.showItem(@(_model.TrackID));">@(EditItem.取消)</a></li>
                </ul>
            </div>
        </td>
    </tr>
