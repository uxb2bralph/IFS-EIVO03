
@using System.Linq
@using System.IO
@using System.Linq.Expressions

@using Newtonsoft.Json
@using eIVOGo.Controllers
@using eIVOGo.Helper
@using eIVOGo.Models
@using eIVOGo.Models.ViewModel
@using Model.Models.ViewModel
@using Model.DataEntity
@using Model.Helper
@using Model.Locale
@using Utility
@using Uxnet.Web.WebUI
@using res = eIVOGo.Resource.Views.InvoiceProcess.Module.ItemTable

@{

    ModelSource<InvoiceItem> models;
    IQueryable<InvoiceItem> _model;
    String _listID = "itemList" + DateTime.Now.Ticks;
    InquireInvoiceViewModel _viewModel;

    models = ((SampleController<InvoiceItem>)ViewContext.Controller).DataSource;
    _model = (IQueryable<InvoiceItem>)this.Model;
    _viewModel = (InquireInvoiceViewModel)ViewBag.ViewModel;

    List<string> amountShow = new List<String>();
}

<table id="@(_listID)" class="table01 itemList">
    <thead>
        <tr>
            <th aria-sort="other">
                <input name="chkAll" type="checkbox" />
            </th>
            <th data-sort="1">@res.日期</th>
            <th data-sort="2">@res.客戶_ID</th>
            <th data-sort="3">@res.序號</th>
            <th data-sort="4">@res.開立發票營業人</th>
            <th data-sort="5">@res.統編</th>
            <th data-sort="6">@res.發票號碼</th>
            <th data-sort="7">@res.未稅金額</th>
            <th data-sort="8">@res.稅額</th>
            <th data-sort="9">@res.含稅金額</th>
            <th aria-sort="other">@res.幣別</th>
            <th data-sort="10">@res.是否中獎</th>
            <th data-sort="11">@res.買受人統編</th>
            <th aria-sort="other">@res.發票狀態</th>
            <th aria-sort="other">@res.名稱</th>
            <th aria-sort="other">@res.連絡人名稱</th>
            <th aria-sort="other">@res.地址</th>
            <th aria-sort="other">@res.email</th>
            <th aria-sort="other">@res.備註</th>
            <th aria-sort="other">@res.開立通知</th>
            <th aria-sort="other">@res.載具資訊</th>
            <th aria-sort="other">@res.列印註記</th>
            <th aria-sort="other" style="min-width: 140px;">@res.管理</th>
        </tr>
    </thead>
    <tbody>
        @{ Html.RenderPartial("~/Views/InvoiceProcess/Module/ItemList.cshtml", _model);}

    </tbody>
    <tfoot>
        <tr>
            <td colspan="25">
                @{
                    foreach (var g in _model.GroupBy(i => i.InvoiceAmountType.CurrencyID))
                    {
                        var currency = g.Key.HasValue ? models.GetTable<CurrencyType>().Where(c => c.CurrencyID == g.Key).FirstOrDefault()?.AbbrevName : "TWD";
                        string totalAmount = res.含稅金額總計 + "(" + currency + ")： " + String.Format("{0:##,###,###,##0}", g.Sum(i => i.InvoiceAmountType.TotalAmount)) + "，";
                        string salesAmount = res.未稅金額總計 + "(" + currency + ")： " + String.Format("{0:##,###,###,##0}", g.Sum(i => i.InvoiceAmountType.SalesAmount)) + "，";
                        string taxAmount = res.稅額總計 + "(" + currency + ")： " + String.Format("{0:##,###,###,##0}", g.Sum(i => i.InvoiceAmountType.TaxAmount)) ;

                        amountShow.Add(totalAmount + salesAmount + taxAmount);
                    }
                }
                
                @foreach (var item in amountShow)
                {
                    @item <br />
                }

                <script>
                    debugger;
                    $(function () {

                        var $table = $('#@(_listID)');

                        uiInvoiceQuery.paging = function (data) {
                            //uiInvoiceQuery.pagePlacement.html(data);
                            var $tbody = $table.find('tbody');
                            $tbody.empty();
                            var $data = $(data);
                            $data.appendTo($('body')).appendTo($tbody);

                            $(".itemList input[name='chkAll']").prop('checked', false);
                            $(".itemList input[name='chkItem']").click(function (e) {
                                if (!$(this).is(':checked')) {
                                    $(".itemList input[name='chkAll']").prop('checked', false);
                                }
                            });
                        };

                        uiInvoiceQuery.sort = (function () {
                            var orderBy = [];

                            initSortable($table, uiInvoiceQuery.inquire, uiInvoiceQuery.pageIndex, orderBy);

                            this.getSort = function () {
                                return orderBy;
                            };

                            return this;
                        })();

                        $(".itemList input[name='chkAll']").click(function () {
                            $(".itemList input[name='chkItem']")
                                .prop('checked', $(this).is(':checked'));
                        });

                        $(".itemList input[name='chkItem']").click(function (e) {
                            if (!$(this).is(':checked')) {
                                $(".itemList input[name='chkAll']").prop('checked', false);
                            }
                        });

                    });
                </script>
            </td>
        </tr>
    </tfoot>
</table>


